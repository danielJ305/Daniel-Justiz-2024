# Copy this file to .env (local) or set these in your host's environment
# settings (Vercel: Project → Settings → Environment Variables).
# Never commit real values — .env is gitignored.

# Gmail account used to send contact-form mail.
MY_EMAIL=your-address@gmail.com
# Gmail App Password (16 chars, requires 2-Step Verification). NOT your
# normal account password. Generate at https://myaccount.google.com → Security → App passwords
MY_PASSWORD=your-16-char-app-password

# Google reCAPTCHA v2 keys: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key
